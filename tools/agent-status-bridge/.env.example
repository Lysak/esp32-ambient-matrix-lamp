# Copy this file to .env and fill in your own values. .env is gitignored.

# Base URL of your Home Assistant instance, no trailing slash.
HA_URL=http://homeassistant.local:8123

# A long-lived access token, created in Home Assistant under your profile.
HA_TOKEN=

# Optional: override the entity id if you named it differently.
HA_ENTITY_ID=input_select.agent_status

# Optional: the ESPHome button pressed when a session finishes (thinking->idle).
HA_FINISHED_BUTTON_ENTITY_ID=button.ambient_matrix_lamp_agent_finished_flash

# Optional: override the shared machine-wide Codex hook log path.
# Default:
# ~/Library/Application Support/ambient-matrix-agent-status/codex-events.log
CODEX_EVENT_LOG_PATH=
